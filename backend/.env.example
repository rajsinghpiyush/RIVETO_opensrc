# ===========================================
# RIVETO Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# Server Configuration
# ===========================================
PORT=3000

# ===========================================
# MongoDB Database
# ===========================================
# Get your MongoDB connection string from https://cloud.mongodb.com/
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Local dev example: mongodb://localhost:27017/riveto

# ===========================================
# JWT Authentication
# ===========================================
# Generate a secure random string for JWT signing
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ===========================================
# Cloudinary Configuration (Image Uploads)
# ===========================================
# Get these from https://console.cloudinary.com/
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# Razorpay Payment Gateway (Optional)
# ===========================================
# Get these from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ===========================================
# GEMINI KEY (Optional)
# ===========================================
# Get these from google ai studio
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# Window duration in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_BOT_MAX=30
RATE_LIMIT_USER_MAX=200
RATE_LIMIT_ADMIN_MAX=100